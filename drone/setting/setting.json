{
    "serverPort": "40002",
    "db": {
        "type": "mysql",
        "host": "localhost",
        "port": "3306",
        "name": "aerowatch",
        "userEnv": "DRONE_DB_USER",
        "passwordEnv": "DRONE_DB_PASSWORD"
    },
    "droneTable": {
        "name": "drone_models",
        "groupColumn": "model_group",
        "codeColumn": "code",
        "statusColumn": "status"
    },
    "status": {
        "active": "active",
        "inactive": "inactive"
    }
}
