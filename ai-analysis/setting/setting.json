{
    "serverPort": "40006",
    "openai": {
        "apiUrl": "https://api.openai.com/v1/responses",
        "model": "gpt-4.1-mini",
        "timeoutSeconds": 60,
        "apiKeyEnv": "OPENAI_API_KEY",
        "textPrePromptEnv": "OPENAI_TEXT_PRE_PROMPT",
        "textPostPromptEnv": "OPENAI_TEXT_POST_PROMPT",
        "imagePrePromptEnv": "OPENAI_IMAGE_PRE_PROMPT",
        "imagePostPromptEnv": "OPENAI_IMAGE_POST_PROMPT"
    }
}
